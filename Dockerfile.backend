# ---- Build Stage ----
FROM node:22-alpine AS builder
RUN corepack enable && corepack prepare pnpm@9 --activate
WORKDIR /app

# Copy workspace manifests for layer caching
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY backend/package.json ./backend/

# Install all deps (workspace-aware)
RUN pnpm install --no-frozen-lockfile

# Copy backend source and build
COPY backend ./backend

WORKDIR /app/backend
RUN pnpm build

# pnpm deploy creates a flat, symlink-free node_modules for production.
# Required in pnpm workspaces: copying .pnpm/ symlinks between Docker
# stages breaks resolution. This produces a safe, fully-resolved output.
WORKDIR /app
RUN pnpm deploy --filter backend --prod --legacy /app/deploy

# ---- Production Stage ----
FROM node:22-alpine
WORKDIR /app

ENV NODE_ENV=production

COPY --from=builder /app/backend/dist ./dist
COPY --from=builder /app/deploy/node_modules ./node_modules

EXPOSE 8080

CMD ["node", "dist/src/main"]
